{
  "name": "cluedo-notebook-ngx",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "clu",
  "sourceRoot": "apps/cluedo-notebook-ngx/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/cluedo-notebook-ngx",
        "browser": "apps/cluedo-notebook-ngx/src/main.ts",
        "tsConfig": "apps/cluedo-notebook-ngx/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/cluedo-notebook-ngx/public"
          }
        ],
        "styles": [
          "apps/cluedo-notebook-ngx/src/styles.css",
          "apps/cluedo-notebook-ngx/src/material-styles.scss"
        ],
        "plugins": [
          "apps/cluedo-notebook-ngx/plugins/app-version-env-plugin.js"
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "cluedo-notebook-ngx:build:production"
        },
        "development": {
          "buildTarget": "cluedo-notebook-ngx:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../coverage/apps/cluedo-notebook-ngx"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "cluedo-notebook-ngx:build",
        "staticFilePath": "dist/apps/cluedo-notebook-ngx/browser",
        "spa": true
      }
    }
  }
}
